# Crevia environment variables — copy to `.env.local` (never commit real secrets).
# Public EXPO_PUBLIC_* keys are bundled into the client; do not put private keys here.

# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# Mirrors EAS Update channel when using OTA (development | preview | production)
EXPO_PUBLIC_BUILD_CHANNEL=development

# RevenueCat public SDK keys (placeholder — replace before IAP sandbox test)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_REPLACE_WITH_REVENUECAT_IOS_PUBLIC_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_REPLACE_WITH_REVENUECAT_ANDROID_PUBLIC_KEY

# Optional RevenueCat app user override (normally derived from device/local id)
# EXPO_PUBLIC_REVENUECAT_APP_USER_ID=

# Future API base URL placeholder (not used in soft launch build prep)
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# Sentry (optional — missing DSN keeps crash reporter in no-op mode; build does not fail)
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_CRASH_REPORTING_ENABLED=true
# EAS build secrets (set via `eas secret:create` — never commit values):
# SENTRY_AUTH_TOKEN
# SENTRY_ORG
# SENTRY_PROJECT

# Analytics endpoint placeholder (optional, not integrated for store prep)
# EXPO_PUBLIC_ANALYTICS_ENDPOINT=
